{
  "name": "minimax-speech",
  "title": "MiniMax Speech",
  "description": "Convert text or file content to speech using MiniMax TTS API",
  "icon": "extension-icon.png",
  "author": "zempty",
  "categories": [
    "Productivity"
  ],
  "license": "MIT",
  "platforms": [
    "macOS"
  ],
  "commands": [
    {
      "name": "text-to-speech",
      "title": "Text to Speech",
      "description": "Convert input text to speech audio file",
      "mode": "no-view",
      "arguments": [
        {
          "name": "text",
          "type": "text",
          "placeholder": "Enter text to convert",
          "required": false
        }
      ]
    },
    {
      "name": "file-to-speech",
      "title": "File to Speech",
      "description": "Convert text file content to speech audio file",
      "mode": "no-view"
    },
    {
      "name": "preview-voice",
      "title": "Preview Voice",
      "description": "Preview the currently selected voice with sample text",
      "mode": "no-view"
    }
  ],
  "preferences": [
    {
      "name": "apiKey",
      "title": "API Key",
      "description": "Your MiniMax API key",
      "type": "password",
      "required": true
    },
    {
      "name": "outputDir",
      "title": "Output Directory",
      "description": "Directory to save generated audio files",
      "type": "directory",
      "required": true
    },
    {
      "name": "model",
      "title": "Model",
      "description": "TTS model to use",
      "type": "dropdown",
      "required": false,
      "default": "speech-2.8-hd",
      "data": [
        {
          "title": "Speech 2.8 HD",
          "value": "speech-2.8-hd"
        },
        {
          "title": "Speech 2.8 Turbo",
          "value": "speech-2.8-turbo"
        },
        {
          "title": "Speech 2.6 HD",
          "value": "speech-2.6-hd"
        },
        {
          "title": "Speech 2.6 Turbo",
          "value": "speech-2.6-turbo"
        }
      ]
    },
    {
      "name": "voiceId",
      "title": "Voice",
      "description": "Voice for speech synthesis",
      "type": "dropdown",
      "required": false,
      "default": "Friendly_Person",
      "data": [
        {
          "title": "Friendly Person",
          "value": "Friendly_Person"
        },
